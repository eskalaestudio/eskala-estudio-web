---
import Embajadora from './Embajadora.astro';
---
<section class="py-14 md:py-16 bg-surface" aria-label="Conoce a Eskala">
  <div class="max-w-3xl mx-auto px-5">
    <Embajadora
      pose="saludando"
      lado="izq"
      ancho="w-32 sm:w-40 md:w-48"
      texto="¡Hola! Soy Eskala 👋 Te ayudo a que tu negocio dé el salto digital, con resultados medibles en cada etapa. ¿Vemos qué necesitas?"
    />
  </div>
</section>
