---
const WHATSAPP = "525618003081"; /* reemplaza por ej. 525512345678 */
const WA_MSG   = encodeURIComponent("Hola Eskala Estudio, quiero saber cómo pueden ayudar a mi negocio.");
const WA_URL   = `https://wa.me/${WHATSAPP}?text=${WA_MSG}`;
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center overflow-hidden bg-dark"
  aria-label="Presentación de Eskala Estudio"
>
  <!-- Fondo: gradiente + grid sutil -->
  <div class="absolute inset-0 bg-gradient-to-br from-dark via-[#16273f] to-dark" aria-hidden="true"></div>
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: linear-gradient(var(--color-accent) 1px, transparent 1px), linear-gradient(90deg, var(--color-accent) 1px, transparent 1px); background-size: 48px 48px;"
    aria-hidden="true"
  ></div>

  <!-- Blob decorativo -->
  <div
    class="absolute top-1/4 right-0 w-[600px] h-[600px] rounded-full opacity-10 blur-3xl pointer-events-none"
    style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto px-5 py-32 md:py-0">
    <div class="max-w-3xl">

      <!-- Eyebrow -->
      <p class="reveal inline-flex items-center gap-2 text-lime text-sm font-semibold tracking-widest uppercase mb-6">
        <span class="w-6 h-px bg-lime"></span>
        Estudio de marketing digital · CDMX
      </p>

      <!-- H1: el diferenciador -->
      <h1 class="reveal delay-100 font-display text-white leading-tight mb-6">
        <span class="block text-4xl md:text-5xl lg:text-6xl font-extrabold">
          No vendemos likes.
        </span>
        <span class="block text-4xl md:text-5xl lg:text-6xl font-extrabold text-lime mt-1">
          Vendemos clientes.
        </span>
        <span class="block text-xl md:text-2xl font-semibold text-white/70 mt-3">
          Y lo medimos.
        </span>
      </h1>

      <!-- Subtítulo -->
      <p class="reveal delay-200 text-white/60 text-lg md:text-xl leading-relaxed mb-10 max-w-xl">
        Llevamos marcas de restaurantes, comercios y clínicas al siguiente nivel
        con publicidad digital que genera ventas reales — no solo aplausos en redes.
      </p>

      <!-- CTAs -->
      <div class="reveal delay-300 flex flex-col sm:flex-row gap-4">
        <!-- CTA primario → WhatsApp -->
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 bg-lime hover:opacity-90 text-dark font-bold text-base px-7 py-4 rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0"
        >
          <!-- WhatsApp icon -->
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Quiero más clientes
        </a>

        <!-- CTA secundario → sección proceso -->
        <a
          href="#proceso"
          class="inline-flex items-center justify-center gap-2 border border-white/25 hover:border-white/50 text-white/80 hover:text-white font-semibold text-base px-7 py-4 rounded-xl transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0"
        >
          Ver cómo trabajamos
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
      </div>

      <!-- Social proof mínimo -->
      <div class="reveal delay-400 flex items-center gap-6 mt-12 pt-12 border-t border-white/10">
        <div class="text-center">
          <p class="text-2xl font-extrabold text-white font-display">+50</p>
          <p class="text-xs text-white/50 mt-0.5">negocios atendidos</p>
        </div>
        <div class="w-px h-10 bg-white/10"></div>
        <div class="text-center">
          <p class="text-2xl font-extrabold text-white font-display">3×</p>
          <p class="text-xs text-white/50 mt-0.5">retorno promedio</p>
        </div>
        <div class="w-px h-10 bg-white/10"></div>
        <div class="text-center">
          <p class="text-2xl font-extrabold text-white font-display">100%</p>
          <p class="text-xs text-white/50 mt-0.5">resultados medibles</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Flecha scroll-down decorativa -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/30 animate-bounce" aria-hidden="true">
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
