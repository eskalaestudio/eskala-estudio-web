---
const WHATSAPP = "525618003081"; /* reemplaza por ej. 525512345678 */
---

<section
  id="contacto"
  class="section-pad bg-surface"
  aria-labelledby="contacto-titulo"
>
  <div class="max-w-6xl mx-auto px-5">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Izquierda: copy -->
      <div>
        <p class="reveal inline-flex items-center gap-2 text-accent text-sm font-semibold tracking-widest uppercase mb-3">
          <span class="w-5 h-px bg-accent"></span>
          Hablemos
        </p>
        <h2 id="contacto-titulo" class="reveal delay-100 text-dark font-display text-3xl md:text-4xl font-extrabold mb-5">
          ¿Listo para dejar<br class="hidden md:block" /> de improvisar?
        </h2>
        <p class="reveal delay-200 text-body text-lg leading-relaxed mb-8">
          Cuéntanos qué negocio tienes y cuál es tu reto principal.
          Sin compromiso — en la primera llamada ya tendrás claridad
          sobre lo que necesitas para crecer.
        </p>

        <div class="reveal delay-300 space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-accent-light flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-dark text-sm">Respuesta rápida</p>
              <p class="text-body text-sm">Te contestamos en menos de 24 horas — normalmente el mismo día.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-accent-light flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-dark text-sm">Sin presiones</p>
              <p class="text-body text-sm">Primera consulta sin costo. Trabajamos solo con negocios con los que podemos generar resultados reales.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Derecha: formulario -->
      <div class="reveal delay-200 bg-white rounded-2xl p-8 border border-border" style="box-shadow: var(--shadow-card);">
        <form id="contact-form" novalidate>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="cf-name" class="block text-sm font-semibold text-dark mb-1.5">Tu nombre</label>
              <input
                id="cf-name"
                name="nombre"
                type="text"
                required
                placeholder="[Tu nombre]"
                class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-dark text-sm placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent transition-colors"
              />
            </div>
            <div>
              <label for="cf-business" class="block text-sm font-semibold text-dark mb-1.5">Tu negocio</label>
              <input
                id="cf-business"
                name="negocio"
                type="text"
                required
                placeholder="[Nombre de tu negocio]"
                class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-dark text-sm placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent transition-colors"
              />
            </div>
          </div>

          <div class="mb-4">
            <label for="cf-wa" class="block text-sm font-semibold text-dark mb-1.5">Tu WhatsApp</label>
            <input
              id="cf-wa"
              name="whatsapp"
              type="tel"
              required
              placeholder="+52 55 1234 5678"
              class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-dark text-sm placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent transition-colors"
            />
          </div>

          <div class="mb-6">
            <label for="cf-msg" class="block text-sm font-semibold text-dark mb-1.5">¿Cuál es tu mayor reto hoy?</label>
            <textarea
              id="cf-msg"
              name="mensaje"
              rows="4"
              required
              placeholder="Ej: Tengo un restaurante y quiero llenar más mesas entre semana..."
              class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-dark text-sm placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full inline-flex items-center justify-center gap-2.5 bg-cta hover:bg-cta-dark text-dark font-bold text-base px-6 py-4 rounded-xl transition-all duration-200 hover:-translate-y-0.5 shadow-lg active:translate-y-0"
          >
            <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>

          <p class="mt-3 text-center text-muted text-xs">
            Al enviar, se abrirá WhatsApp con tu mensaje prellenado.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ WHATSAPP }}>
  const form = document.getElementById("contact-form");
  if (form) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();

      const nombre   = form.querySelector("#cf-name").value.trim();
      const negocio  = form.querySelector("#cf-business").value.trim();
      const wa       = form.querySelector("#cf-wa").value.trim();
      const mensaje  = form.querySelector("#cf-msg").value.trim();

      if (!nombre || !negocio || !wa || !mensaje) {
        alert("Por favor completa todos los campos.");
        return;
      }

      const text = `Hola Eskala Estudio! 👋\n\nSoy *${nombre}* y tengo el negocio *${negocio}*.\n📱 Mi WhatsApp: ${wa}\n\n*Mi reto:*\n${mensaje}`;
      const url  = `https://wa.me/${WHATSAPP}?text=${encodeURIComponent(text)}`;
      window.open(url, "_blank", "noopener,noreferrer");
    });
  }
</script>
