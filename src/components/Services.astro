---
const services = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.9L15 14M3 8a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/></svg>`,
    title:   "Contenido y video que convierte",
    benefit: "Tu negocio se ve profesional, genera confianza y atrae clientes nuevos — sin que tú tengas que escribir una sola palabra ni pararte frente a una cámara.",
    tag:     "Producción",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>`,
    title:   "Publicidad que paga por resultados",
    benefit: "Invertimos tu presupuesto en Google, Meta, TikTok y Microsoft Ads para traer clientes que ya están buscando lo que vendes — no para presumir alcance.",
    tag:     "Pauta digital",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    title:   "Página web que vende las 24 hrs",
    benefit: "Un sitio rápido, bonito y pensado para convertir visitas en llamadas, reservas o ventas — no solo para \"tener presencia en internet\".",
    tag:     "Web",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
    title:   "Estrategia para crecer con cabeza",
    benefit: "Definimos junto contigo cómo llegar a más clientes, cuánto invertir y cómo medir que cada peso trabaje — para que dejes de improvisar y empieces a escalar.",
    tag:     "Estrategia",
  },
];
---

<section
  id="servicios"
  class="section-pad bg-surface"
  aria-labelledby="servicios-titulo"
>
  <div class="max-w-6xl mx-auto px-5">

    <!-- Encabezado -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="reveal inline-flex items-center gap-2 text-accent text-sm font-semibold tracking-widest uppercase mb-3">
        <span class="w-5 h-px bg-accent"></span>
        Lo que hacemos
        <span class="w-5 h-px bg-accent"></span>
      </p>
      <h2 id="servicios-titulo" class="reveal delay-100 text-dark font-display text-3xl md:text-4xl font-extrabold mb-4">
        Todo lo que necesita tu negocio<br class="hidden md:block" /> para vender más en internet
      </h2>
      <p class="reveal delay-200 text-body text-lg">
        No ofrecemos servicios sueltos. Construimos ecosistemas digitales que generan clientes de forma constante.
      </p>
    </div>

    <!-- Grid de tarjetas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((s, i) => (
        <article
          class={`reveal delay-${(i + 1) * 100} group bg-white rounded-2xl p-6 border border-border hover:border-accent/30 transition-all duration-300 hover:-translate-y-1`}
          style={`box-shadow: var(--shadow-card);`}
        >
          <!-- Ícono -->
          <div class="w-12 h-12 rounded-xl bg-accent-light flex items-center justify-center mb-5 group-hover:bg-accent group-hover:text-white transition-colors duration-300 text-accent [&_svg]:w-6 [&_svg]:h-6">
            <Fragment set:html={s.icon} />
          </div>

          <!-- Tag -->
          <span class="inline-block text-xs font-semibold text-accent/80 bg-accent-light rounded-full px-3 py-0.5 mb-3">
            {s.tag}
          </span>

          <!-- Título -->
          <h3 class="font-display font-bold text-dark text-lg leading-snug mb-3">
            {s.title}
          </h3>

          <!-- Beneficio -->
          <p class="text-body text-sm leading-relaxed">
            {s.benefit}
          </p>
        </article>
      ))}
    </div>

  </div>
</section>
