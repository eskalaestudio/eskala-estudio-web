---
/* ─────────────────────────────────────────────────────────────
   PLACEHOLDER — Reemplaza cada objeto con un caso real.
   Campos:
     giro        → tipo de negocio (aparece como etiqueta)
     name        → nombre del negocio (o "Cliente confidencial")
     challenge   → problema que tenían antes de trabajar contigo
     solution    → qué hizo Eskala Estudio
     metrics     → array de { label, before, after }
     image       → ruta en /public/images/cases/ (formato webp)
     quote       → testimonio del cliente (opcional)
     quoteAuthor → nombre del dueño / cargo
   ──────────────────────────────────────────────────────────── */
const cases = [
  {
    giro:      "Restaurante",
    name:      "[NOMBRE_RESTAURANTE]",
    challenge: "[Descripción del problema antes de trabajar con Eskala Estudio — ej. bajas ventas los martes y miércoles, dependencia de reparto externo con comisiones altas]",
    solution:  "[Qué hicieron: campañas de Meta Ads geo-segmentadas, contenido de video mensual, página de pedidos directos]",
    metrics: [
      { label: "Reservas por semana", before: "[N]", after: "[N]" },
      { label: "Costo por cliente nuevo", before: "$[X]", after: "$[X]" },
      { label: "Pedidos directos (sin comisión)", before: "[N]%", after: "[N]%" },
    ],
    image:       "/images/cases/restaurante.webp",
    quote:       "[Testimonio del dueño del restaurante sobre el resultado obtenido con Eskala Estudio.]",
    quoteAuthor: "[NOMBRE_DUEÑO], Propietario",
  },
  {
    giro:      "Comercio local",
    name:      "[NOMBRE_COMERCIO]",
    challenge: "[Descripción del problema — ej. mucho tráfico a la tienda física pero nula presencia digital, temporadas muertas muy marcadas]",
    solution:  "[Qué hicieron: Google Ads local, rediseño de web con catálogo, estrategia de contenido orgánico]",
    metrics: [
      { label: "Visitas web al mes", before: "[N]", after: "[N]" },
      { label: "Ventas online",      before: "$[X]", after: "$[X]" },
      { label: "ROI de pauta",       before: "[N]×", after: "[N]×" },
    ],
    image:       "/images/cases/comercio.webp",
    quote:       "[Testimonio del dueño del comercio sobre el impacto en ventas.]",
    quoteAuthor: "[NOMBRE_DUEÑO], Dueño",
  },
  {
    giro:      "Clínica",
    name:      "[NOMBRE_CLÍNICA]",
    challenge: "[Descripción del problema — ej. agenda con huecos, poca diferenciación ante la competencia, dependencia de referencias boca a boca]",
    solution:  "[Qué hicieron: SEO local + Google Ads para servicios específicos, video de presentación del equipo médico, landing de citas]",
    metrics: [
      { label: "Nuevos pacientes / mes", before: "[N]", after: "[N]" },
      { label: "Citas agendadas online", before: "[N]%", after: "[N]%" },
      { label: "Costo por paciente nuevo", before: "$[X]", after: "$[X]" },
    ],
    image:       "/images/cases/clinica.webp",
    quote:       "[Testimonio del director médico sobre la transformación digital de la clínica.]",
    quoteAuthor: "[NOMBRE_DIRECTOR], Director Médico",
  },
];
---

<section
  id="resultados"
  class="section-pad bg-surface"
  aria-labelledby="resultados-titulo"
>
  <div class="max-w-6xl mx-auto px-5">

    <!-- Encabezado -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="reveal inline-flex items-center gap-2 text-accent text-sm font-semibold tracking-widest uppercase mb-3">
        <span class="w-5 h-px bg-accent"></span>
        Casos de éxito
        <span class="w-5 h-px bg-accent"></span>
      </p>
      <h2 id="resultados-titulo" class="reveal delay-100 text-dark font-display text-3xl md:text-4xl font-extrabold mb-4">
        Números reales,<br class="hidden md:block" /> no promesas
      </h2>
      <p class="reveal delay-200 text-body text-lg">
        Aquí no mostramos likes ni impresiones. Mostramos lo que de verdad le importa a un dueño de negocio.
      </p>
    </div>

    <!-- Cards de casos -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {cases.map((c, i) => (
        <article
          class={`reveal delay-${(i + 1) * 100} bg-white rounded-2xl overflow-hidden border border-border flex flex-col`}
          style="box-shadow: var(--shadow-card);"
        >
          <!-- Imagen placeholder -->
          <div class="relative h-44 bg-accent-light flex items-center justify-center overflow-hidden">
            <img
              src={c.image}
              alt={`Caso de éxito ${c.giro} — Eskala Estudio`}
              loading="lazy"
              width="400"
              height="176"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'"
            />
            <!-- Fallback si no hay imagen -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-accent/40">
              <svg class="w-12 h-12 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
              </svg>
              <span class="text-xs font-semibold">Imagen del caso</span>
            </div>

            <!-- Etiqueta giro -->
            <span class="absolute top-3 left-3 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full">
              {c.giro}
            </span>
          </div>

          <div class="p-6 flex flex-col flex-1">
            <!-- Nombre negocio -->
            <h3 class="font-display font-extrabold text-dark text-xl mb-2">{c.name}</h3>

            <!-- Reto -->
            <p class="text-muted text-xs font-semibold uppercase tracking-wider mb-1">El reto</p>
            <p class="text-body text-sm leading-relaxed mb-4">{c.challenge}</p>

            <!-- Solución -->
            <p class="text-muted text-xs font-semibold uppercase tracking-wider mb-1">Lo que hicimos</p>
            <p class="text-body text-sm leading-relaxed mb-5">{c.solution}</p>

            <!-- Métricas antes / después -->
            <div class="border-t border-border pt-5 mb-5">
              <p class="text-muted text-xs font-semibold uppercase tracking-wider mb-3">Resultados</p>
              <div class="space-y-3">
                {c.metrics.map((m) => (
                  <div class="flex items-center justify-between gap-2">
                    <span class="text-body text-xs">{m.label}</span>
                    <div class="flex items-center gap-2 shrink-0">
                      <span class="text-xs text-muted line-through">{m.before}</span>
                      <svg class="w-3 h-3 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      <span class="text-sm font-bold text-accent">{m.after}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Testimonio -->
            {c.quote && (
              <blockquote class="mt-auto bg-accent-light rounded-xl p-4 border-l-4 border-accent">
                <p class="text-dark text-sm italic leading-relaxed mb-2">"{c.quote}"</p>
                <footer class="text-muted text-xs font-semibold">— {c.quoteAuthor}</footer>
              </blockquote>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Nota al pie -->
    <p class="reveal mt-10 text-center text-muted text-sm">
      ¿Tu negocio podría ser el siguiente caso de éxito?
      <a href="#contacto" class="text-accent font-semibold hover:underline ml-1">Hablemos →</a>
    </p>

  </div>
</section>
