---
/* Video de intro con fondo animado tipo red + aviso de sonido. Autoplay silenciado (regla del navegador). */
---
<section class="relative bg-dark pt-24 pb-12 md:pt-28 md:pb-16 overflow-hidden">
  <!-- Fondo animado: red de nodos -->
  <canvas id="net-canvas" class="absolute inset-0 w-full h-full pointer-events-none opacity-60" aria-hidden="true"></canvas>

  <div class="relative z-10 max-w-5xl mx-auto px-5">
    <div class="relative rounded-2xl overflow-hidden mx-auto bg-black" style="box-shadow: var(--shadow-hover);">
      <video
        id="intro-video"
        class="w-full h-auto block"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/videointro-poster.jpg"
        aria-label="Video de presentación de Eskala Estudio"
      >
        <source src="/videointro.mp4" type="video/mp4" />
      </video>

      <!-- Aviso: toca para activar sonido -->
      <button
        id="sound-overlay"
        type="button"
        class="absolute inset-0 z-20 flex items-end justify-center pb-6 bg-gradient-to-t from-black/40 via-transparent to-transparent cursor-pointer transition-opacity duration-300"
        aria-label="Activar sonido del video"
      >
        <span class="inline-flex items-center gap-2 bg-mint text-dark font-bold text-sm px-4 py-2.5 rounded-full shadow-lg animate-pulse">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z"/></svg>
          Toca para activar sonido
        </span>
      </button>

      <!-- Botón persistente de sonido -->
      <button
        id="video-sound"
        type="button"
        aria-label="Activar sonido"
        aria-pressed="false"
        class="absolute bottom-4 right-4 z-30 w-11 h-11 rounded-full bg-dark/60 backdrop-blur-sm border border-white/20 text-white hover:bg-dark hover:border-mint/50 flex items-center justify-center transition-colors duration-200"
      >
        <svg class="icon-muted w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75 19.5 12m0 0 2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z"/>
        </svg>
        <svg class="icon-unmuted w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  /* ---- Sonido ---- */
  const video = document.getElementById("intro-video") as HTMLVideoElement | null;
  const btn = document.getElementById("video-sound");
  const overlay = document.getElementById("sound-overlay");
  if (video && btn) {
    const iconMuted = btn.querySelector(".icon-muted");
    const iconUnmuted = btn.querySelector(".icon-unmuted");
    const setMuted = (muted: boolean) => {
      video.muted = muted;
      iconMuted?.classList.toggle("hidden", !muted);
      iconUnmuted?.classList.toggle("hidden", muted);
      btn.setAttribute("aria-pressed", String(!muted));
      btn.setAttribute("aria-label", muted ? "Activar sonido" : "Silenciar");
      if (!muted) video.play().catch(() => {});
      if (overlay) overlay.style.display = "none";
    };
    overlay?.addEventListener("click", () => setMuted(false));
    btn.addEventListener("click", () => setMuted(!video.muted));
  }

  /* ---- Fondo animado: red de nodos ---- */
  const canvas = document.getElementById("net-canvas") as HTMLCanvasElement | null;
  const section = canvas?.parentElement;
  if (canvas && section) {
    const ctx = canvas.getContext("2d")!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const COLORS = ["#2EE6A5", "#86EFCA"];
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let w = 0, h = 0, parts: any[] = [], raf = 0;

    const sizeCanvas = () => {
      const r = section.getBoundingClientRect();
      w = canvas.width = Math.max(1, Math.floor(r.width * dpr));
      h = canvas.height = Math.max(1, Math.floor(r.height * dpr));
    };
    const initParts = () => {
      const count = Math.min(60, Math.floor((w * h) / (26000 * dpr)));
      parts = Array.from({ length: Math.max(24, count) }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.22 * dpr,
        vy: (Math.random() - 0.5) * 0.22 * dpr,
        r: (Math.random() * 1.4 + 1.1) * dpr,
        c: COLORS[(Math.random() * COLORS.length) | 0],
      }));
    };
    const render = (move: boolean) => {
      ctx.clearRect(0, 0, w, h);
      const link = 130 * dpr;
      for (let i = 0; i < parts.length; i++) {
        const p = parts[i];
        if (move) {
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0 || p.x > w) p.vx *= -1;
          if (p.y < 0 || p.y > h) p.vy *= -1;
        }
        for (let j = i + 1; j < parts.length; j++) {
          const q = parts[j];
          const dx = p.x - q.x, dy = p.y - q.y;
          const d = Math.hypot(dx, dy);
          if (d < link) {
            ctx.globalAlpha = (1 - d / link) * 0.22;
            ctx.strokeStyle = p.c;
            ctx.lineWidth = dpr;
            ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(q.x, q.y); ctx.stroke();
          }
        }
      }
      for (const p of parts) {
        ctx.globalAlpha = 0.85;
        ctx.fillStyle = p.c;
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalAlpha = 1;
    };
    const loop = () => { render(true); raf = requestAnimationFrame(loop); };
    const start = () => { sizeCanvas(); initParts(); if (reduce) render(false); else { cancelAnimationFrame(raf); loop(); } };

    start();
    const ro = new ResizeObserver(() => { sizeCanvas(); initParts(); if (reduce) render(false); });
    ro.observe(section);
  }
</script>
