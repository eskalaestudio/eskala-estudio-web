---
import BaseLayout  from '../../layouts/BaseLayout.astro';
import Navbar      from '../../components/Navbar.astro';
import Footer      from '../../components/Footer.astro';
import WhatsAppFAB from '../../components/WhatsAppFAB.astro';
import { planes } from '../../data/planes';

export function getStaticPaths() {
  return planes.map((p) => ({ params: { slug: p.slug }, props: { plan: p } }));
}

const { plan } = Astro.props;

const WHATSAPP = "525618003081";
const waMsg = encodeURIComponent(`Hola Eskala Estudio, me interesa el plan ${plan.nombre}. ¿Me dan más información?`);
const waUrl = `https://wa.me/${WHATSAPP}?text=${waMsg}`;

const otros = planes.filter((p) => p.slug !== plan.slug);
---

<BaseLayout
  title={`${plan.nombre} — Eskala Estudio`}
  description={plan.tagline}
>
  <Navbar />

  <main>
    <!-- ===== HERO DEL PLAN ===== -->
    <section class="relative bg-dark text-white pt-28 pb-16 md:pt-32 md:pb-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-dark via-[#16273f] to-dark" aria-hidden="true"></div>
      <div
        class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-10 blur-3xl pointer-events-none"
        style="background: radial-gradient(circle, var(--color-mint) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative max-w-5xl mx-auto px-5">
        <a href="/#planes" class="inline-flex items-center gap-1.5 text-white/50 hover:text-mint text-sm font-medium mb-8 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7"/></svg>
          Todos los planes
        </a>

        <p class="text-mint text-sm font-semibold tracking-widest uppercase mb-4">
          {plan.linea === "A" ? "Web & Local" : "Marketing & Pauta"} · Plan
        </p>
        <h1 class="font-display text-4xl md:text-6xl font-extrabold tracking-tight mb-4">
          {plan.nombre}
        </h1>
        <p class="text-white/70 text-xl md:text-2xl font-medium max-w-2xl mb-8">
          {plan.tagline}
        </p>

        <p class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm text-white/80 mb-10">
          <span class="w-2 h-2 rounded-full bg-mint"></span>
          Ideal para: {plan.paraQuien}
        </p>

        <div>
          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 bg-mint hover:opacity-90 text-dark font-bold text-base px-7 py-4 rounded-xl transition-all duration-200 shadow-lg hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
            Me interesa este plan
          </a>
        </div>
      </div>
    </section>

    <!-- ===== EL PROBLEMA ===== -->
    <section class="section-pad bg-white">
      <div class="max-w-3xl mx-auto px-5">
        <p class="reveal inline-flex items-center gap-2 text-accent text-sm font-semibold tracking-widest uppercase mb-3">
          <span class="w-5 h-px bg-accent"></span> El problema que resolvemos
        </p>
        <p class="reveal delay-100 text-dark text-xl md:text-2xl font-display font-bold leading-snug">
          {plan.problema}
        </p>
      </div>
    </section>

    <!-- ===== QUÉ INCLUYE ===== -->
    <section class="section-pad bg-surface">
      <div class="max-w-3xl mx-auto px-5">
        <h2 class="reveal font-display text-2xl md:text-3xl font-extrabold text-dark mb-8">Qué incluye</h2>
        <ul class="grid gap-3 list-none p-0 m-0">
          {plan.incluye.map((item, i) => (
            <li class={`reveal delay-${Math.min((i + 1) * 100, 400)} flex items-start gap-3 bg-white rounded-xl p-4 border border-border`} style="box-shadow: var(--shadow-card);">
              <svg class="w-5 h-5 shrink-0 mt-0.5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
              <span class="text-body">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ===== CÓMO LO HACEMOS ===== -->
    <section class="section-pad bg-white">
      <div class="max-w-4xl mx-auto px-5">
        <h2 class="reveal font-display text-2xl md:text-3xl font-extrabold text-dark mb-2">Cómo lo hacemos</h2>
        <p class="reveal delay-100 text-body mb-10">Nuestro proceso, paso a paso, con entregables y métricas claras.</p>
        <div class="grid gap-6 sm:grid-cols-2">
          {plan.proceso.map((p, i) => (
            <div class={`reveal delay-${Math.min((i + 1) * 100, 400)} relative bg-surface rounded-2xl p-6 border border-border`} style="box-shadow: var(--shadow-card);">
              <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-accent text-white font-display font-extrabold text-sm mb-4">{i + 1}</span>
              <h3 class="font-display font-bold text-dark text-lg mb-2">{p.paso}</h3>
              <p class="text-body text-sm leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== RESULTADO ESPERADO ===== -->
    <section class="section-pad bg-dark text-white">
      <div class="max-w-3xl mx-auto px-5 text-center">
        <p class="reveal inline-flex items-center gap-2 text-mint text-sm font-semibold tracking-widest uppercase mb-4 justify-center">
          <span class="w-5 h-px bg-mint"></span> El resultado <span class="w-5 h-px bg-mint"></span>
        </p>
        <p class="reveal delay-100 font-display text-2xl md:text-3xl font-bold leading-snug">{plan.resultado}</p>
      </div>
    </section>

    <!-- ===== PARA QUIÉN ES / NO ES ===== -->
    <section class="section-pad bg-white">
      <div class="max-w-4xl mx-auto px-5 grid gap-6 md:grid-cols-2">
        <div class="reveal bg-accent-light rounded-2xl p-7">
          <h3 class="font-display font-bold text-dark text-lg mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            Este plan es para ti si…
          </h3>
          <ul class="grid gap-2.5 list-none p-0 m-0">
            {plan.idealSi.map((item) => (
              <li class="flex items-start gap-2 text-body text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-2 shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal delay-100 bg-surface rounded-2xl p-7 border border-border">
          <h3 class="font-display font-bold text-dark text-lg mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
            Quizá no es para ti si…
          </h3>
          <p class="text-body text-sm leading-relaxed">{plan.noSi}</p>
        </div>
      </div>

      {plan.notaPauta && (
        <div class="max-w-4xl mx-auto px-5 mt-6">
          <div class="reveal bg-dark text-white/80 rounded-2xl p-5 text-sm flex items-start gap-3">
            <svg class="w-5 h-5 shrink-0 mt-0.5 text-mint" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><strong class="text-white">Transparencia total:</strong> la inversión en anuncios (pauta) la pagas directo a la plataforma con tu propio método de pago. Nunca pasa por nosotros — ves cada peso invertido.</span>
          </div>
        </div>
      )}
    </section>

    <!-- ===== CTA FINAL ===== -->
    <section class="section-pad bg-surface">
      <div class="max-w-3xl mx-auto px-5">
        <div class="reveal bg-accent rounded-3xl p-10 md:p-12 text-center text-white" style="box-shadow: var(--shadow-hover);">
          <h2 class="font-display text-2xl md:text-3xl font-extrabold mb-3">¿Te interesa el plan {plan.nombre}?</h2>
          <p class="text-white/85 mb-8 max-w-xl mx-auto">Cuéntanos de tu negocio y te armamos una propuesta a la medida. Sin compromiso — el precio lo vemos juntos.</p>
          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 bg-mint hover:opacity-90 text-dark font-bold text-base px-7 py-4 rounded-xl transition-all duration-200 hover:-translate-y-0.5"
          >
            Escríbenos por WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- ===== OTROS PLANES ===== -->
    <section class="section-pad bg-white border-t border-border">
      <div class="max-w-5xl mx-auto px-5">
        <h2 class="reveal font-display text-xl font-extrabold text-dark mb-6">Otros planes</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {otros.map((p) => (
            <a href={`/planes/${p.slug}`} class="group flex flex-col rounded-xl p-5 border border-border bg-surface hover:border-accent/40 hover:-translate-y-0.5 transition-all" style="box-shadow: var(--shadow-card);">
              <span class="text-xs font-semibold text-accent/70 uppercase tracking-wide mb-1">{p.lineaLabel}</span>
              <span class="font-display font-bold text-dark group-hover:text-accent transition-colors">{p.nombre}</span>
              <span class="text-muted text-sm mt-1">{p.tagline}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFAB />
</BaseLayout>
